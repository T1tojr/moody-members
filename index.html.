// ════════════════════════════════
// ACTIVITY LOG
// ════════════════════════════════
function logActivity(name,action,pts){
  activity.push({customerName:name,action,points:pts,date:new Date().toLocaleDateString()});
  if(activity.length>200)activity.splice(0,activity.length-200);
}

function adjustPointsPrompt(id){
  const c=customers.find(x=>x.id===id); if(!c)return;
  const input=prompt(`Adjust points for ${c.name}\nCurrent balance: ${c.points} pts\n\nEnter amount (use + to add, - to subtract):\nExamples: +50 or -100`);
  if(input===null||input.trim()==='') return;
  const raw=input.trim();
  const num=parseInt(raw);
  if(isNaN(num)){toast('Invalid number. Use +50 or -100 format.');return;}
  const before=c.points;
  c.points=Math.max(0,c.points+num);
  const actual=c.points-before;
  const note=raw.startsWith('-')?`Points deducted: ${Math.abs(num)}`:`Points added: ${num}`;
  logActivity(c.name,'Manual adjustment (admin)',actual);
  save();
  toast(`✅ ${c.name}: ${actual>=0?'+':''}${actual} pts → New total: ${c.points}`);
  // refresh whichever view is active
  const detailView=document.getElementById('view-customer-detail');
  if(detailView&&detailView.classList.contains('active')){
    showCustomerDetail(id);
  } else {
    renderCustomers('');
  }
}

function removeService(customerId, histIndex){
  const c=customers.find(x=>x.id===customerId); if(!c) return;
  const entry=c.history[histIndex]; if(!entry) return;
  if(!confirm(`Remove this service?\n\n${entry.type} — $${entry.amount} — ${entry.date}\n\nThis will also deduct ${entry.points} points from ${c.name}'s balance.`)) return;
  // deduct the points
  c.points=Math.max(0, c.points - entry.points);
  c.totalSpent=Math.max(0, c.totalSpent - parseFloat(entry.amount));
  c.visits=Math.max(0, c.visits - 1);
  // remove the history entry
  c.history.splice(histIndex, 1);
  logActivity(c.name, `Service removed: ${entry.type}`, -entry.points);
  save();
  toast(`✅ Service removed. -${entry.points} pts from ${c.name}.`);
  showCustomerDetail(customerId);
}

function removeCustomer(id){
  const c=customers.find(x=>x.id===id); if(!c)return;
  if(!confirm(`Remove ${c.name} from the loyalty program?\n\nThis will permanently delete their account and all service history.`)) return;
  customers=customers.filter(x=>x.id!==id);
  logActivity(c.name,'Account removed by admin',0);
  save();
  toast(`${c.name} has been removed.`);
  const detailView=document.getElementById('view-customer-detail');
  if(detailView&&detailView.classList.contains('active')){
    showView('customers');
  } else {
    renderCustomers('');
  }
}
</script>
