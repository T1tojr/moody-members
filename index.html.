<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Moody Performance Loyalty</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#fff; min-height:100vh; }

    /* ── NAV ── */
    .nav { display:flex; justify-content:space-between; align-items:center; padding:18px 32px; background:#111; border-bottom:2px solid #e05c2a; }
    .nav-logo { font-size:22px; font-weight:900; letter-spacing:2px; color:#e05c2a; }
    .nav-tabs  { display:flex; gap:12px; }
    .nav-tab   { padding:8px 18px; border-radius:6px; border:none; cursor:pointer; font-weight:600; font-size:13px; background:transparent; color:#aaa; transition:all .2s; }
    .nav-tab.active,.nav-tab:hover { background:#e05c2a; color:#fff; }
    .nav-user  { display:flex; align-items:center; gap:10px; font-size:13px; color:#aaa; }
    .nav-user strong { color:#fff; }
    .nav-user button { background:transparent; border:1px solid #444; color:#aaa; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .nav-user button:hover { border-color:#e05c2a; color:#e05c2a; }

    /* ── VIEWS ── */
    .view { display:none; padding:32px; max-width:960px; margin:0 auto; }
    .view.active { display:block; }

    /* ── CARDS ── */
    .card { background:#1a1a1a; border:1px solid #2a2a2a; border-radius:12px; padding:24px; margin-bottom:20px; }
    .card-title { font-size:13px; text-transform:uppercase; letter-spacing:1.5px; color:#e05c2a; margin-bottom:8px; font-weight:700; }
    .card-value { font-size:36px; font-weight:900; }
    .card-sub   { font-size:13px; color:#888; margin-top:4px; }

    /* ── GRIDS ── */
    .grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
    .grid-2 { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }

    /* ── TIER BADGES ── */
    .tier-badge { display:inline-block; padding:6px 16px; border-radius:20px; font-weight:700; font-size:14px; margin-bottom:12px; }
    .tier-STOCK { background:#333; color:#ccc; }
    .tier-TUNED { background:#1a3a1a; color:#4caf50; }
    .tier-BUILT { background:#1a2a4a; color:#64b5f6; }
    .tier-ELITE { background:#3a1a0a; color:#e05c2a; }

    /* ── PROGRESS ── */
    .progress-wrap { background:#2a2a2a; border-radius:99px; height:12px; margin:12px 0 6px; overflow:hidden; }
    .progress-bar  { height:12px; border-radius:99px; background:linear-gradient(90deg,#e05c2a,#ff8c55); transition:width .6s ease; }
    .progress-label { font-size:12px; color:#888; }

    /* ── PERKS ── */
    .perks { list-style:none; margin-top:10px; }
    .perks li { padding:6px 0; font-size:14px; color:#ccc; border-bottom:1px solid #222; }
    .perks li::before { content:"✓ "; color:#e05c2a; font-weight:700; }

    /* ── FORMS ── */
    .form-group { margin-bottom:16px; }
    label { display:block; font-size:13px; color:#aaa; margin-bottom:6px; font-weight:600; }
    input,select,textarea { width:100%; background:#222; border:1px solid #333; border-radius:8px; padding:10px 14px; color:#fff; font-size:14px; outline:none; transition:border .2s; }
    input:focus,select:focus { border-color:#e05c2a; }
    select option { background:#222; }

    /* ── BUTTONS ── */
    .btn { padding:12px 24px; border-radius:8px; border:none; cursor:pointer; font-weight:700; font-size:14px; transition:all .2s; }
    .btn-primary   { background:#e05c2a; color:#fff; }
    .btn-primary:hover { background:#c44e22; }
    .btn-secondary { background:#2a2a2a; color:#ccc; }
    .btn-secondary:hover { background:#333; }
    .btn-sm { padding:6px 14px; font-size:12px; }
    .btn-outline { background:transparent; border:1px solid #e05c2a; color:#e05c2a; }
    .btn-outline:hover { background:#e05c2a; color:#fff; }

    /* ── TABLE ── */
    table { width:100%; border-collapse:collapse; font-size:14px; }
    th { text-align:left; padding:10px 12px; color:#e05c2a; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #2a2a2a; }
    td { padding:12px; border-bottom:1px solid #1e1e1e; color:#ccc; }
    tr:hover td { background:#1e1e1e; }

    /* ── SETTINGS ── */
    .setting-row { display:flex; align-items:center; justify-content:space-between; padding:14px 0; border-bottom:1px solid #222; }
    .setting-row:last-child { border-bottom:none; }
    .setting-label { font-size:14px; color:#ccc; }
    .setting-desc  { font-size:12px; color:#666; margin-top:2px; }
    .setting-input { width:80px; text-align:center; }

    /* ── TOAST ── */
    #toast { position:fixed; bottom:24px; right:24px; background:#e05c2a; color:#fff; padding:12px 24px; border-radius:8px; font-weight:600; font-size:14px; display:none; z-index:999; animation:fadeIn .3s; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

    /* ── MISC ── */
    .section-title { font-size:22px; font-weight:900; margin-bottom:20px; }
    .flex-between  { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
    .search-input  { max-width:260px; }

    /* ════════════════════════════════════════
       CUSTOMER PORTAL STYLES
    ════════════════════════════════════════ */

    /* Login Screen */
    #screen-login {
      display:flex; align-items:center; justify-content:center;
      min-height:100vh; background:#0a0a0a;
    }
    .login-box {
      background:#111; border:1px solid #2a2a2a; border-radius:16px;
      padding:48px 40px; width:100%; max-width:420px; text-align:center;
    }
    .login-logo { font-size:28px; font-weight:900; color:#e05c2a; letter-spacing:3px; margin-bottom:6px; }
    .login-sub  { font-size:14px; color:#666; margin-bottom:32px; }
    .login-toggle { display:flex; background:#1a1a1a; border-radius:8px; margin-bottom:24px; overflow:hidden; }
    .login-toggle button { flex:1; padding:10px; border:none; background:transparent; color:#888; font-size:13px; font-weight:600; cursor:pointer; transition:all .2s; }
    .login-toggle button.active { background:#e05c2a; color:#fff; }

    /* Member Portal Hero */
    .portal-hero {
      background:linear-gradient(135deg,#1a0a00,#2a1205);
      border:1px solid #3a2010; border-radius:16px;
      padding:32px; margin-bottom:24px; position:relative; overflow:hidden;
    }
    .portal-hero::before {
      content:''; position:absolute; top:-40px; right:-40px;
      width:180px; height:180px; border-radius:50%;
      background:radial-gradient(circle,rgba(224,92,42,.15),transparent 70%);
    }
    .portal-hero-name  { font-size:28px; font-weight:900; margin-bottom:4px; }
    .portal-hero-vehicle { font-size:14px; color:#888; margin-bottom:16px; }
    .portal-hero-pts   { font-size:56px; font-weight:900; color:#e05c2a; line-height:1; }
    .portal-hero-ptslabel { font-size:14px; color:#888; margin-top:4px; margin-bottom:20px; }
    .portal-tier-row   { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }

    /* Tier road */
    .tier-road {
      display:flex; gap:0; margin:24px 0 8px; position:relative;
    }
    .tier-road::before {
      content:''; position:absolute; top:50%; left:0; right:0; height:3px;
      background:#2a2a2a; transform:translateY(-50%); z-index:0;
    }
    .tier-stop {
      flex:1; display:flex; flex-direction:column; align-items:center;
      position:relative; z-index:1;
    }
    .tier-stop-dot {
      width:20px; height:20px; border-radius:50%; border:3px solid #2a2a2a;
      background:#0a0a0a; transition:all .3s;
    }
    .tier-stop.done .tier-stop-dot  { background:#e05c2a; border-color:#e05c2a; }
    .tier-stop.curr .tier-stop-dot  { background:#fff; border-color:#e05c2a; box-shadow:0 0 0 4px rgba(224,92,42,.3); }
    .tier-stop-label { font-size:10px; color:#555; margin-top:6px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; }
    .tier-stop.done .tier-stop-label,
    .tier-stop.curr .tier-stop-label { color:#e05c2a; }

    /* Redeem cards */
    .redeem-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
    .redeem-card {
      background:#1a1a1a; border:1px solid #2a2a2a; border-radius:12px;
      padding:18px; text-align:center; transition:border .2s;
    }
    .redeem-card:hover { border-color:#e05c2a; }
    .redeem-card.locked { opacity:.45; pointer-events:none; }
    .redeem-icon  { font-size:28px; margin-bottom:8px; }
    .redeem-title { font-size:14px; font-weight:700; margin-bottom:4px; }
    .redeem-cost  { font-size:12px; color:#e05c2a; font-weight:700; margin-bottom:10px; }
    .redeem-avail { font-size:11px; color:#555; }

    /* Activity timeline */
    .timeline { list-style:none; }
    .timeline li { display:flex; gap:14px; padding:12px 0; border-bottom:1px solid #1e1e1e; align-items:flex-start; }
    .timeline li:last-child { border-bottom:none; }
    .tl-dot { width:10px; height:10px; border-radius:50%; background:#e05c2a; margin-top:5px; flex-shrink:0; }
    .tl-info { flex:1; }
    .tl-title { font-size:14px; color:#ccc; }
    .tl-date  { font-size:12px; color:#555; margin-top:2px; }
    .tl-pts   { font-size:14px; font-weight:700; color:#e05c2a; white-space:nowrap; }

    @media(max-width:600px){
      .grid-3,.grid-2,.redeem-grid{grid-template-columns:1fr;}
      .nav{flex-direction:column;gap:12px;}
      .login-box{padding:32px 20px;}
      .portal-hero-pts{font-size:40px;}
    }
  </style>
</head>
<body>

<!-- ════════════════════════════════════════════════════
     LOGIN / REGISTER SCREEN
════════════════════════════════════════════════════ -->
<div id="screen-login">
  <div class="login-box">
    <div class="login-logo">MOODY</div>
    <div class="login-sub">Performance Loyalty Program</div>

    <div class="login-toggle">
      <button class="active" id="toggle-login-btn" onclick="switchAuth('login')">Member Login</button>
      <button id="toggle-reg-btn" onclick="switchAuth('register')">Register</button>
      <button id="toggle-admin-btn" onclick="switchAuth('admin')">Shop Admin</button>
    </div>

    <!-- LOGIN FORM -->
    <div id="auth-login" style="display:block;">
      <div class="form-group"><label>Username</label><input type="text" id="login-username" placeholder="your username" autocomplete="username"></div>
      <div class="form-group"><label>Password</label><input type="password" id="login-pass" placeholder="••••••••"></div>
      <button class="btn btn-primary" style="width:100%;margin-top:4px;" onclick="loginCustomer()">Log In</button>
      <div id="login-error" style="color:#e05c2a;font-size:13px;margin-top:10px;display:none;"></div>
    </div>

    <!-- REGISTER FORM -->
    <div id="auth-register" style="display:none;">
      <div class="form-group"><label>Full Name</label><input type="text" id="reg-name" placeholder="John Smith"></div>
      <div class="form-group"><label>Username</label><input type="text" id="reg-username" placeholder="choose a username" autocomplete="username"></div>
      <div class="form-group"><label>Email (optional)</label><input type="email" id="reg-email" placeholder="your@email.com"></div>
      <div class="form-group"><label>Phone</label><input type="tel" id="reg-phone" placeholder="(909) 555-0000"></div>
      <div class="form-group"><label>Vehicle (Year / Make / Model)</label><input type="text" id="reg-vehicle" placeholder="2020 Honda Civic Si"></div>
      <div class="form-group"><label>Password</label><input type="password" id="reg-pass" placeholder="Create a password"></div>
      <div class="form-group"><label>Referred By (optional)</label><input type="text" id="reg-referrer" placeholder="Who referred you?"></div>
      <button class="btn btn-primary" style="width:100%;margin-top:4px;" onclick="registerCustomer()">Create Account</button>
      <div id="reg-error" style="color:#e05c2a;font-size:13px;margin-top:10px;display:none;"></div>
    </div>

    <!-- ADMIN LOGIN -->
    <div id="auth-admin" style="display:none;">
      <div style="font-size:13px;color:#666;margin-bottom:20px;">Staff access only. Enter the shop admin password to continue.</div>
      <div class="form-group"><label>Admin Password</label><input type="password" id="admin-pass" placeholder="••••••••"></div>
      <button class="btn btn-primary" style="width:100%;margin-top:4px;" onclick="loginAdmin()">Enter Shop Dashboard</button>
      <div id="admin-error" style="color:#e05c2a;font-size:13px;margin-top:10px;display:none;"></div>
    </div>
  </div>
</div>

<!-- ════════════════════════════════════════════════════
     MAIN APP (shown after login)
════════════════════════════════════════════════════ -->
<div id="screen-app" style="display:none;">

  <!-- NAV -->
  <div class="nav" id="main-nav">
    <div class="nav-logo">MOODY MEMBERS</div>
    <div class="nav-tabs" id="admin-tabs">
      <button class="nav-tab active" onclick="showView('dashboard')">Dashboard</button>
      <button class="nav-tab" onclick="showView('customers')">Customers</button>
      <button class="nav-tab" onclick="showView('log-service')">Log Service</button>
      <button class="nav-tab" onclick="showView('settings')">Settings</button>
    </div>
    <div class="nav-tabs" id="portal-tabs" style="display:none;">
      <button class="nav-tab active" onclick="showPortalView('my-profile')">My Profile</button>
      <button class="nav-tab" onclick="showPortalView('my-history')">Service History</button>
      <button class="nav-tab" onclick="showPortalView('my-redeem')">Redeem Points</button>
    </div>
    <div class="nav-user" id="nav-user-info">
      <span>Logged in as <strong id="nav-username"></strong></span>
      <button onclick="logout()">Log Out</button>
    </div>
  </div>

  <div id="toast"></div>

  <!-- ══════════════════════════════════════
       ADMIN: DASHBOARD
  ══════════════════════════════════════ -->
  <div id="view-dashboard" class="view active">
    <div class="section-title">Shop Overview</div>
    <div class="grid-3" style="margin-bottom:20px;">
      <div class="card"><div class="card-title">Total Customers</div><div class="card-value" id="stat-customers">0</div><div class="card-sub">Enrolled members</div></div>
      <div class="card"><div class="card-title">Points Issued</div><div class="card-value" id="stat-points">0</div><div class="card-sub">All time</div></div>
      <div class="card"><div class="card-title">Revenue Tracked</div><div class="card-value" id="stat-revenue">$0</div><div class="card-sub">Via loyalty program</div></div>
    </div>
    <div class="card"><div class="card-title">Tier Breakdown</div><div class="grid-2" style="margin-top:12px;" id="tier-breakdown"></div></div>
    <div class="card"><div class="card-title">Recent Activity</div>
      <table><thead><tr><th>Customer</th><th>Action</th><th>Points</th><th>Date</th></tr></thead>
      <tbody id="recent-activity"></tbody></table>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       ADMIN: CUSTOMERS
  ══════════════════════════════════════ -->
  <div id="view-customers" class="view">
    <div class="flex-between">
      <div class="section-title" style="margin-bottom:0;">Customers</div>
      <button class="btn btn-primary" onclick="showView('add-customer')">+ Add Customer</button>
    </div>
    <input class="search-input" type="text" placeholder="Search by name or email…" oninput="filterCustomers(this.value)" style="margin-bottom:20px;">
    <div id="customer-list"></div>
  </div>

  <div id="view-customer-detail" class="view">
    <button class="btn btn-secondary btn-sm" onclick="showView('customers')" style="margin-bottom:20px;">← Back</button>
    <div id="customer-detail-content"></div>
  </div>

  <div id="view-add-customer" class="view">
    <button class="btn btn-secondary btn-sm" onclick="showView('customers')" style="margin-bottom:20px;">← Back</button>
    <div class="section-title">Add New Customer</div>
    <div class="card">
      <div class="form-group"><label>Full Name</label><input type="text" id="new-name" placeholder="e.g. John Smith"></div>
      <div class="form-group"><label>Username (for member login)</label><input type="text" id="new-username" placeholder="e.g. jsmith92"></div>
      <div class="form-group"><label>Email</label><input type="email" id="new-email" placeholder="john@email.com"></div>
      <div class="form-group"><label>Phone</label><input type="tel" id="new-phone" placeholder="(909) 555-0000"></div>
      <div class="form-group"><label>Vehicle</label><input type="text" id="new-vehicle" placeholder="2020 Honda Civic Si"></div>
      <div class="form-group"><label>Password (for member login)</label><input type="password" id="new-pass" placeholder="Set their password"></div>
      <div class="form-group"><label>Referred By (optional)</label><input type="text" id="new-referrer" placeholder="Who referred them?"></div>
      <button class="btn btn-primary" onclick="addCustomer()">Create Customer</button>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       ADMIN: LOG SERVICE
  ══════════════════════════════════════ -->
  <div id="view-log-service" class="view">
    <div class="section-title">Log a Service</div>
    <div class="card">
      <div class="form-group"><label>Customer</label><select id="svc-customer"><option value="">-- Select Customer --</option></select></div>
      <div class="form-group"><label>Service Type</label>
        <select id="svc-type">
          <option>Dyno Tune</option><option>ECU Flash / Remap</option><option>Suspension Install</option>
          <option>Exhaust Install</option><option>Engine Build</option><option>Turbo / Supercharger Install</option>
          <option>Oil Change</option><option>Diagnostic Scan</option><option>Brake Service</option>
          <option>Custom Fabrication</option><option>Other</option>
        </select>
      </div>
      <div class="form-group"><label>Amount Charged ($)</label><input type="number" id="svc-amount" placeholder="0.00" min="0"></div>
      <div class="form-group"><label>Notes (optional)</label><textarea id="svc-notes" rows="3" placeholder="Service details…"></textarea></div>
      <div class="form-group"><label>Date</label><input type="date" id="svc-date"></div>
      <div style="background:#1e1e1e;border-radius:8px;padding:14px;margin-bottom:16px;font-size:14px;color:#aaa;" id="svc-preview">Select a customer and amount to preview points.</div>
      <button class="btn btn-primary" onclick="logService()">Log Service & Award Points</button>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       ADMIN: SETTINGS
  ══════════════════════════════════════ -->
  <div id="view-settings" class="view">
    <div class="section-title">Program Settings</div>
    <div class="card">
      <div class="card-title">Points Rules</div>
      <div class="setting-row"><div><div class="setting-label">Points per $1 spent</div><div class="setting-desc">$1 = X points</div></div><input class="setting-input" type="number" id="cfg-spend-pts" value="2" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">Points per referral</div><div class="setting-desc">Awarded on referral's first service</div></div><input class="setting-input" type="number" id="cfg-ref-pts" value="3" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">Points per Google review</div><div class="setting-desc">One-time bonus</div></div><input class="setting-input" type="number" id="cfg-review-pts" value="5" min="0"></div>
    </div>
    <div class="card">
      <div class="card-title">Tier Thresholds</div>
      <div class="setting-row"><div><div class="setting-label">⚙️ TUNED starts at (pts)</div></div><input class="setting-input" type="number" id="cfg-tuned" value="200" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">🚀 BUILT starts at (pts)</div></div><input class="setting-input" type="number" id="cfg-built" value="500" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">🏁 MOODY ELITE starts at (pts)</div></div><input class="setting-input" type="number" id="cfg-elite" value="1000" min="1"></div>
    </div>
    <div class="card">
      <div class="card-title">Redemption Costs</div>
      <div class="setting-row"><div><div class="setting-label">Points for $5 off</div></div><input class="setting-input" type="number" id="cfg-redeem-5" value="100" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">Points for $15 off</div></div><input class="setting-input" type="number" id="cfg-redeem-15" value="250" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">Points for $30 credit</div></div><input class="setting-input" type="number" id="cfg-redeem-30" value="500" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">Points for free oil change</div></div><input class="setting-input" type="number" id="cfg-redeem-oil" value="750" min="1"></div>
      <div class="setting-row"><div><div class="setting-label">Admin username</div></div><input class="setting-input" type="text" id="cfg-admin-user" placeholder="Moody"></div>
      <div class="setting-row"><div><div class="setting-label">Admin password</div></div><input class="setting-input" type="password" id="cfg-admin-pass" placeholder="••••••••"></div>
    </div>
    <button class="btn btn-primary" onclick="saveSettings()">Save Settings</button>
  </div>

  <!-- ══════════════════════════════════════
       CUSTOMER PORTAL: MY PROFILE
  ══════════════════════════════════════ -->
  <div id="view-my-profile" class="view">

    <!-- HERO -->
    <div class="portal-hero" id="portal-hero"></div>

    <!-- TIER ROAD -->
    <div class="card">
      <div class="card-title">Your Journey</div>
      <div class="tier-road" id="tier-road"></div>
      <div class="progress-wrap" style="margin-top:16px;">
        <div class="progress-bar" id="portal-progress-bar" style="width:0%"></div>
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:6px;">
        <span style="font-size:12px;color:#888;" id="portal-progress-left"></span>
        <span style="font-size:12px;color:#e05c2a;font-weight:700;" id="portal-progress-pct"></span>
      </div>
    </div>

    <!-- STATS -->
    <div class="grid-3" style="margin-bottom:20px;" id="portal-stats"></div>

    <!-- PERKS -->
    <div class="card" id="portal-perks"></div>

    <!-- NEXT TIER PREVIEW -->
    <div class="card" id="portal-next-tier"></div>

  </div>

  <!-- ══════════════════════════════════════
       CUSTOMER PORTAL: SERVICE HISTORY
  ══════════════════════════════════════ -->
