    <div class="section-title">Redeem Your Points</div>
    <div class="card" style="margin-bottom:20px;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div><div class="card-title">Available Balance</div><div class="card-value" style="color:#e05c2a;" id="redeem-balance">0 pts</div></div>
        <div style="text-align:right;font-size:13px;color:#888;">Points never expire</div>
      </div>
    </div>
    <div class="redeem-grid" id="redeem-options"></div>
