    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <div><div style="font-size:26px;font-weight:900;">${c.name}</div>
      <div style="color:#888;font-size:14px;">${c.email} · ${c.phone}</div>
      <div style="color:#666;font-size:13px;">${c.vehicle}</div></div>
