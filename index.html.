      <div class="card"><div class="card-title">Total Spent</div><div class="card-value">$${c.totalSpent.toLocaleString()}</div></div>
      <div class="card"><div class="card-title">Referrals</div><div class="card-value">${c.referrals}</div></div>
    </div>
    <div class="card" style="margin-bottom:20px;">
      <div class="card-title">Tier Progress</div>
      <div class="progress-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>
      <div class="progress-label">${next?`${c.points}/${next.threshold} pts to ${next.name}`:'🏁 Max tier reached!'}</div>
      <ul class="perks" style="margin-top:12px;">${tierPerks(key).map(p=>`<li>${p}</li>`).join('')}</ul>
    </div>
    <div class="card"><div class="card-title">Service History</div>
      <table><thead><tr><th>Date</th><th>Service</th><th>Amount</th><th>Pts</th><th>Notes</th><th></th></tr></thead>
      <tbody>${hist}</tbody></table>
    </div>
    <div style="margin-top:16px;display:flex;gap:12px;flex-wrap:wrap;">
      <button class="btn btn-primary" onclick="awardReferral('${c.id}')">+ Referral Bonus</button>
      <button class="btn btn-secondary" onclick="awardReview('${c.id}')">+ Google Review</button>
      <button class="btn btn-outline" onclick="adjustPointsPrompt('${c.id}')">✏️ Adjust Points</button>
      <button class="btn" style="background:#3a0a0a;color:#e05c2a;border:1px solid #5a1a1a;" onclick="removeCustomer('${c.id}')">🗑 Remove Member</button>
    </div>`;
  showView('customer-detail');
}

function awardReferral(id){
  const c=customers.find(x=>x.id===id); if(!c)return;
  c.points+=config.refPts; c.referrals++;
  logActivity(c.name,'Referral bonus',config.refPts); save();
  toast(`+${config.refPts} referral pts → ${c.name}`);
  showCustomerDetail(id);
}
function awardReview(id){
  const c=customers.find(x=>x.id===id); if(!c)return;
  c.points+=config.reviewPts;
  logActivity(c.name,'Google Review bonus',config.reviewPts); save();
  toast(`+${config.reviewPts} review pts → ${c.name}`);
  showCustomerDetail(id);
}

// ════════════════════════════════
// ADMIN: ADD CUSTOMER
// ════════════════════════════════
function addCustomer(){
  const name=document.getElementById('new-name').value.trim();
  const username=document.getElementById('new-username').value.trim().toLowerCase();
  const email=document.getElementById('new-email').value.trim().toLowerCase();
  const phone=document.getElementById('new-phone').value.trim();
  const vehicle=document.getElementById('new-vehicle').value.trim();
  const pass=document.getElementById('new-pass').value;
  const referrer=document.getElementById('new-referrer').value.trim();
  if(!name){toast('Name is required!');return;}
  if(username && customers.find(x=>(x.username||'').toLowerCase()===username)){toast('Username already taken!');return;}
  const c={id:Date.now().toString(),name,username,email,phone,vehicle,password:pass,
    points:0,totalSpent:0,referrals:0,visits:0,history:[],joined:new Date().toLocaleDateString()};
  customers.push(c);
  if(referrer){
    const ref=customers.find(x=>x.name.toLowerCase()===referrer.toLowerCase());
    if(ref){ref.points+=config.refPts;ref.referrals++;logActivity(ref.name,`Referral: ${name} joined`,config.refPts);}
  }
  logActivity(name,'Joined loyalty program',0); save();
  toast(`${name} added!`);
  ['new-name','new-username','new-email','new-phone','new-vehicle','new-pass','new-referrer'].forEach(id=>document.getElementById(id).value='');
  showView('customers');
}

// ════════════════════════════════
// ADMIN: LOG SERVICE
// ════════════════════════════════
function populateCustomerSelect(){
  const sel=document.getElementById('svc-customer');
  sel.innerHTML='<option value="">-- Select Customer --</option>'+customers.map(c=>`<option value="${c.id}">${c.name}</option>`).join('');
  sel.onchange=updateSvcPreview;
  document.getElementById('svc-amount').oninput=updateSvcPreview;
}
function updateSvcPreview(){
  const id=document.getElementById('svc-customer').value;
  const amt=parseFloat(document.getElementById('svc-amount').value)||0;
  const c=customers.find(x=>x.id===id),pts=Math.floor(amt*config.spendPts);
  const el=document.getElementById('svc-preview');
  if(c&&amt>0){
    const newPts=c.points+pts;
    el.innerHTML=`<strong style="color:#e05c2a;">${c.name}</strong> earns <strong style="color:#e05c2a;">+${pts} pts</strong> for $${amt.toFixed(2)}<br>New total: <strong>${newPts.toLocaleString()} pts</strong> → <strong>${getTierName(newPts)}</strong>`;
  } else el.textContent='Select a customer and amount to preview points.';
}
function logService(){
  const id=document.getElementById('svc-customer').value;
  const type=document.getElementById('svc-type').value;
  const amt=parseFloat(document.getElementById('svc-amount').value);
  const notes=document.getElementById('svc-notes').value.trim();
  const date=document.getElementById('svc-date').value;
  const c=customers.find(x=>x.id===id);
  if(!c){toast('Select a customer!');return;}
  if(!amt||amt<=0){toast('Enter a valid amount!');return;}
  const pts=Math.floor(amt*config.spendPts);
  c.points+=pts; c.totalSpent+=amt; c.visits++;
  c.history.push({date,type,amount:amt.toFixed(2),points:pts,notes});
  logActivity(c.name,type,pts); save();
  toast(`✅ ${c.name} earned +${pts} pts!`);
  document.getElementById('svc-customer').value='';
  document.getElementById('svc-amount').value='';
  document.getElementById('svc-notes').value='';
  document.getElementById('svc-preview').textContent='Select a customer and amount to preview points.';
}

