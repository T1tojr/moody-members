<script>
// ════════════════════════════════
// STATE
// ════════════════════════════════
let customers = JSON.parse(localStorage.getItem('moody_customers') || '[]');
let activity  = JSON.parse(localStorage.getItem('moody_activity')  || '[]');
const _defaults = {
  spendPts:2, refPts:3, reviewPts:5,
  tuned:200, built:500, elite:1000,
  redeem5:100, redeem15:250, redeem30:500, redeemOil:750,
  adminPass:'Malik0509',
  adminUser:'Moody'
};
let config = Object.assign({}, _defaults, JSON.parse(localStorage.getItem('moody_config') || '{}'));
// Always enforce correct admin credentials unless user has explicitly changed them
if(config.adminPass==='moody2024') config.adminPass='Malik0509';
save();

let currentUser = null; // { type:'admin' } or { type:'customer', id:'...' }

// ════════════════════════════════
// TIER HELPERS
// ════════════════════════════════
function getTierKey(pts) {
  if(pts>=config.elite) return 'ELITE';
  if(pts>=config.built) return 'BUILT';
  if(pts>=config.tuned) return 'TUNED';
  return 'STOCK';
}
function getTierName(pts) {
  return {STOCK:'STOCK',TUNED:'TUNED',BUILT:'BUILT',ELITE:'MOODY ELITE'}[getTierKey(pts)];
}
function getTierEmoji(key){return{STOCK:'🔧',TUNED:'⚙️',BUILT:'🚀',ELITE:'🏁'}[key];}
function nextTierInfo(pts) {
  if(pts<config.tuned) return {name:'TUNED',threshold:config.tuned,emoji:'⚙️'};
  if(pts<config.built) return {name:'BUILT',threshold:config.built,emoji:'🚀'};
  if(pts<config.elite) return {name:'MOODY ELITE',threshold:config.elite,emoji:'🏁'};
  return null;
}
function tierPerks(key){
  return {
    STOCK:['5% off your first service','Access to member-only deals'],
    TUNED:['5% off all services','Priority scheduling','10% off in your birthday month'],
    BUILT:['10% off all services','Free diagnostic scan every visit','Early access to new products','Invited to exclusive shop events'],
    ELITE:['15% off all services','Free oil change once per year','Dedicated service advisor','Wall of Fame + exclusive merch drops']
  }[key]||[];
}
function prevTierThreshold(pts){
  if(pts>=config.elite) return config.elite;
  if(pts>=config.built) return config.built;
  if(pts>=config.tuned) return config.tuned;
  return 0;
}

// ════════════════════════════════
// SAVE
// ════════════════════════════════
function save(){
  localStorage.setItem('moody_customers',JSON.stringify(customers));
  localStorage.setItem('moody_activity',JSON.stringify(activity));
  localStorage.setItem('moody_config',JSON.stringify(config));
}

// ════════════════════════════════
// TOAST
// ════════════════════════════════
function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.style.display='block';
  setTimeout(()=>t.style.display='none',2800);
}

// ════════════════════════════════
// AUTH
// ════════════════════════════════
function switchAuth(tab){
  ['login','register','admin'].forEach(t=>{
    const el=document.getElementById('auth-'+t);
    if(el){ el.style.display = (t===tab)?'block':'none'; }
    const btn=document.getElementById('toggle-'+t+'-btn');
    if(btn){ btn.classList.toggle('active',t===tab); }
  });
}

function loginCustomer(){
  const username=document.getElementById('login-username').value.trim().toLowerCase();
  const pass=document.getElementById('login-pass').value;
  const c=customers.find(x=>(x.username||'').toLowerCase()===username && x.password===pass);
  const err=document.getElementById('login-error');
  if(!c){err.textContent='Username or password incorrect.';err.style.display='block';return;}
  err.style.display='none';
  currentUser={type:'customer',id:c.id};
  enterApp();
}

function registerCustomer(){
  const name=document.getElementById('reg-name').value.trim();
  const username=document.getElementById('reg-username').value.trim().toLowerCase();
  const email=document.getElementById('reg-email').value.trim().toLowerCase();
  const phone=document.getElementById('reg-phone').value.trim();
  const vehicle=document.getElementById('reg-vehicle').value.trim();
  const pass=document.getElementById('reg-pass').value;
  const referrer=document.getElementById('reg-referrer').value.trim();
  const err=document.getElementById('reg-error');
  if(!name||!username||!pass){err.textContent='Name, username and password are required.';err.style.display='block';return;}
  if(customers.find(x=>(x.username||'').toLowerCase()===username)){err.textContent='That username is already taken.';err.style.display='block';return;}
  const c={id:Date.now().toString(),name,username,email,phone,vehicle,password:pass,
    points:0,totalSpent:0,referrals:0,visits:0,history:[],joined:new Date().toLocaleDateString()};
  customers.push(c);
  if(referrer){
    const ref=customers.find(x=>x.name.toLowerCase()===referrer.toLowerCase());
    if(ref){ref.points+=config.refPts;ref.referrals++;logActivity(ref.name,`Referral: ${name} joined`,config.refPts);}
  }
  logActivity(name,'Joined loyalty program',0);
  save();
  err.style.display='none';
  currentUser={type:'customer',id:c.id};
  enterApp();
}

// ensure correct tab shown on load
window.addEventListener('DOMContentLoaded', function(){
  switchAuth('login');
});

function loginAdmin(){
  const pass=document.getElementById('admin-pass').value;
  const err=document.getElementById('admin-error');
  if(pass!==config.adminPass){err.textContent='Incorrect password.';err.style.display='block';return;}
  err.style.display='none';
  currentUser={type:'admin'};
  enterApp();
}

function logout(){
  currentUser=null;
  document.getElementById('screen-app').style.display='none';
  document.getElementById('screen-login').style.display='flex';
  ['login-username','login-pass','admin-pass'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';}); 
  switchAuth('login');
}

function enterApp(){
  document.getElementById('screen-login').style.display='none';
  document.getElementById('screen-app').style.display='block';
  const isAdmin=currentUser.type==='admin';
  document.getElementById('admin-tabs').style.display   = isAdmin?'flex':'none';
  document.getElementById('portal-tabs').style.display  = isAdmin?'none':'flex';
  document.getElementById('nav-username').textContent   = isAdmin?'Admin':customers.find(x=>x.id===currentUser.id)?.name||'';

  if(isAdmin){
    showView('dashboard');
  } else {
    // hide all admin views
    ['dashboard','customers','customer-detail','add-customer','log-service','settings'].forEach(v=>{
      const el=document.getElementById('view-'+v); if(el) el.style.display='none';
    });
    showPortalView('my-profile');
  }
}

// ════════════════════════════════
// ADMIN VIEWS
// ════════════════════════════════
function showView(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('#admin-tabs .nav-tab').forEach(t=>t.classList.remove('active'));
  const el=document.getElementById('view-'+id);
  if(el){el.classList.add('active');el.style.display='block';}
  const map={dashboard:0,customers:1,'log-service':2,settings:3};
  if(map[id]!==undefined) document.querySelectorAll('#admin-tabs .nav-tab')[map[id]]?.classList.add('active');
  if(id==='dashboard')   renderDashboard();
  if(id==='customers')   renderCustomers('');
  if(id==='log-service') populateCustomerSelect();
  if(id==='settings')    loadSettings();
  const d=document.getElementById('svc-date'); if(d)d.value=new Date().toISOString().split('T')[0];
}

// ════════════════════════════════
// CUSTOMER PORTAL VIEWS
// ════════════════════════════════
function showPortalView(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('#portal-tabs .nav-tab').forEach(t=>t.classList.remove('active'));
  const el=document.getElementById('view-'+id); if(el){el.classList.add('active');el.style.display='block';}
  const map={'my-profile':0,'my-history':1,'my-redeem':2};
  if(map[id]!==undefined) document.querySelectorAll('#portal-tabs .nav-tab')[map[id]]?.classList.add('active');
  if(id==='my-profile') renderPortalProfile();
  if(id==='my-history') renderPortalHistory();
  if(id==='my-redeem')  renderPortalRedeem();
}

// ════════════════════════════════
// PORTAL: PROFILE
// ════════════════════════════════
function renderPortalProfile(){
  const c=customers.find(x=>x.id===currentUser.id); if(!c) return;
  const key=getTierKey(c.points);
  const tierColors={STOCK:'#888',TUNED:'#4caf50',BUILT:'#64b5f6',ELITE:'#e05c2a'};
  const col=tierColors[key];
  const next=nextTierInfo(c.points);
  const prev=prevTierThreshold(c.points);
  const pct=next ? Math.min(100,Math.round(((c.points-prev)/(next.threshold-prev))*100)) : 100;

  // HERO
  document.getElementById('portal-hero').innerHTML=`
    <div class="portal-hero-name">Welcome back, ${c.name.split(' ')[0]} 👋</div>
    <div class="portal-hero-vehicle">${c.vehicle||'Moody Performance Member'}</div>
    <div class="portal-hero-pts">${c.points.toLocaleString()}</div>
    <div class="portal-hero-ptslabel">Available Points</div>
    <div class="portal-tier-row">
      <span class="tier-badge tier-${key}" style="margin-bottom:0;font-size:16px;">${getTierEmoji(key)} ${getTierName(c.points)}</span>
      ${next ? `<span style="font-size:13px;color:#888;">${next.threshold-c.points} pts until ${next.emoji} ${next.name}</span>` : '<span style="font-size:13px;color:#e05c2a;">🏁 You\'ve reached the top tier!</span>'}
    </div>`;

  // TIER ROAD
  const tiers=[
    {key:'STOCK',label:'STOCK',threshold:0,emoji:'🔧'},
    {key:'TUNED',label:'TUNED',threshold:config.tuned,emoji:'⚙️'},
    {key:'BUILT',label:'BUILT',threshold:config.built,emoji:'🚀'},
    {key:'ELITE',label:'ELITE',threshold:config.elite,emoji:'🏁'}
  ];
  const currentIdx=tiers.findIndex(t=>t.key===key);
  document.getElementById('tier-road').innerHTML=tiers.map((t,i)=>{
    const cls=i<currentIdx?'done':i===currentIdx?'curr':'';
    return `<div class="tier-stop ${cls}"><div class="tier-stop-dot"></div><div class="tier-stop-label">${t.emoji} ${t.label}</div></div>`;
  }).join('');

  // PROGRESS BAR
  document.getElementById('portal-progress-bar').style.width=pct+'%';
  if(next){
    document.getElementById('portal-progress-left').textContent=`${c.points} / ${next.threshold} pts`;
    document.getElementById('portal-progress-pct').textContent=pct+'% to '+next.name;
  } else {
    document.getElementById('portal-progress-left').textContent='Max tier achieved';
    document.getElementById('portal-progress-pct').textContent='🏁 Elite';
  }

  // STATS
  document.getElementById('portal-stats').innerHTML=`
    <div class="card"><div class="card-title">Total Spent</div><div class="card-value">$${c.totalSpent.toLocaleString()}</div><div class="card-sub">At Moody Performance</div></div>
    <div class="card"><div class="card-title">Referrals Made</div><div class="card-value">${c.referrals}</div><div class="card-sub">Friends brought in</div></div>
    <div class="card"><div class="card-title">Shop Visits</div><div class="card-value">${c.visits}</div><div class="card-sub">Services completed</div></div>`;

  // PERKS
  const perks=tierPerks(key);
  document.getElementById('portal-perks').innerHTML=`
    <div class="card-title">${getTierEmoji(key)} Your ${getTierName(c.points)} Perks</div>
    <ul class="perks" style="margin-top:12px;">${perks.map(p=>`<li>${p}</li>`).join('')}</ul>`;

  // NEXT TIER
  if(next){
    const nextPerks=tierPerks(next.key||{TUNED:'TUNED',BUILT:'BUILT','MOODY ELITE':'ELITE'}[next.name]||'ELITE');
    document.getElementById('portal-next-tier').innerHTML=`
      <div class="card-title" style="color:#888;">Next Tier — ${next.emoji} ${next.name}</div>
      <div style="font-size:13px;color:#666;margin-bottom:12px;">Earn ${(next.threshold-c.points).toLocaleString()} more points to unlock:</div>
      <ul class="perks">${nextPerks.map(p=>`<li style="color:#666;">${p}</li>`).join('')}</ul>`;
  } else {
    document.getElementById('portal-next-tier').innerHTML=`
      <div style="text-align:center;padding:12px;">
        <div style="font-size:28px;margin-bottom:8px;">🏁</div>
        <div style="font-weight:700;color:#e05c2a;">You're at the top — MOODY ELITE</div>
        <div style="font-size:13px;color:#666;margin-top:6px;">Thank you for being a loyal Moody Performance customer.</div>
      </div>`;
  }
}

// ════════════════════════════════
// PORTAL: HISTORY
// ════════════════════════════════
function renderPortalHistory(){
  const c=customers.find(x=>x.id===currentUser.id); if(!c) return;
  const hist=[...(c.history||[])].reverse();
  document.getElementById('portal-timeline').innerHTML=hist.length?hist.map(h=>`
    <li>
      <div class="tl-dot" style="background:${h.points<0?'#888':'#e05c2a'};"></div>
      <div class="tl-info">
        <div class="tl-title">${h.type}</div>
        <div class="tl-date">${h.date}${h.notes?` · ${h.notes}`:''}</div>
        ${parseFloat(h.amount)>0?`<div style="font-size:13px;color:#888;margin-top:2px;">Amount: $${h.amount}</div>`:''}
      </div>
      <div class="tl-pts" style="color:${h.points<0?'#888':'#e05c2a'}">${h.points<0?'':'+'}${h.points} pts</div>
    </li>`).join('')
  :'<li style="color:#555;text-align:center;padding:20px;">No services logged yet.</li>';
}

// ════════════════════════════════
// PORTAL: REDEEM
// ════════════════════════════════
function renderPortalRedeem(){
  const c=customers.find(x=>x.id===currentUser.id); if(!c) return;
  document.getElementById('redeem-balance').textContent=c.points.toLocaleString()+' pts';
  const rewards=[
    {icon:'🏷️',title:'$5 Off Your Next Service',cost:config.redeem5,id:'r5'},
    {icon:'💵',title:'$15 Off Your Next Service',cost:config.redeem15,id:'r15'},
    {icon:'💳',title:'$30 Shop Credit',cost:config.redeem30,id:'r30'},
    {icon:'🛢️',title:'Free Oil Change',cost:config.redeemOil,id:'roil'},
  ];
  document.getElementById('redeem-options').innerHTML=rewards.map(r=>{
    const canAfford=c.points>=r.cost;
    return `<div class="redeem-card ${canAfford?'':'locked'}">
      <div class="redeem-icon">${r.icon}</div>
      <div class="redeem-title">${r.title}</div>
      <div class="redeem-cost">${r.cost.toLocaleString()} points</div>
      ${canAfford
        ? `<button class="btn btn-outline btn-sm" onclick="redeemReward('${r.id}',${r.cost},'${r.title}')">Redeem</button>`
        : `<div class="redeem-avail">Need ${(r.cost-c.points).toLocaleString()} more pts</div>`}
    </div>`;
  }).join('');
}

function redeemReward(id,cost,title){
  const c=customers.find(x=>x.id===currentUser.id); if(!c) return;
  if(c.points<cost){toast('Not enough points!');return;}
  if(!confirm(`Redeem ${cost} points for "${title}"?\n\nShow this to shop staff to complete your redemption.`)) return;
  c.points-=cost;
  // push into service history so it shows in My History
  if(!c.history) c.history=[];
  c.history.push({
    date: new Date().toLocaleDateString(),
    type: '🎁 Redemption: ' + title,
    amount: '0.00',
    points: -cost,
    notes: 'Show to staff at Moody Performance'
  });
  logActivity(c.name,`Redeemed: ${title}`,-cost);
  save();
  toast(`✅ Redeemed! Show staff your screen.`);
  renderPortalRedeem();
  // update hero pts too
  const heroEl=document.getElementById('portal-hero');
  if(heroEl) renderPortalProfile();
}

// ════════════════════════════════
// ADMIN: DASHBOARD
// ════════════════════════════════
function renderDashboard(){
  document.getElementById('stat-customers').textContent=customers.length;
  document.getElementById('stat-points').textContent=customers.reduce((s,c)=>s+c.points,0).toLocaleString();
  document.getElementById('stat-revenue').textContent='$'+customers.reduce((s,c)=>s+c.totalSpent,0).toLocaleString();
  const tiers={STOCK:0,TUNED:0,BUILT:0,ELITE:0};
  customers.forEach(c=>tiers[getTierKey(c.points)]++);
  const colors={STOCK:'#555',TUNED:'#4caf50',BUILT:'#64b5f6',ELITE:'#e05c2a'};
  const emojis={STOCK:'🔧',TUNED:'⚙️',BUILT:'🚀',ELITE:'🏁'};
  document.getElementById('tier-breakdown').innerHTML=Object.entries(tiers).map(([k,v])=>
    `<div style="background:#111;border-radius:8px;padding:14px;border-left:4px solid ${colors[k]}">
      <div style="font-size:13px;color:#aaa;">${emojis[k]} ${k}</div>
      <div style="font-size:28px;font-weight:900;color:${colors[k]}">${v}</div>
      <div style="font-size:12px;color:#666;">customers</div></div>`).join('');
  const recent=[...activity].reverse().slice(0,8);
  document.getElementById('recent-activity').innerHTML=recent.length?recent.map(a=>
    `<tr><td>${a.customerName}</td><td>${a.action}</td>
     <td style="color:${a.points>=0?'#e05c2a':'#888'};font-weight:700;">${a.points>=0?'+':''}${a.points} pts</td>
     <td style="color:#666;">${a.date}</td></tr>`).join('')
  :'<tr><td colspan="4" style="color:#555;text-align:center;padding:20px;">No activity yet</td></tr>';
}

// ════════════════════════════════
// ADMIN: CUSTOMERS
// ════════════════════════════════
function renderCustomers(filter){
