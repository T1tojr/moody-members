    c.name.toLowerCase().includes(filter.toLowerCase())||
    (c.email||'').toLowerCase().includes(filter.toLowerCase())
  );
  document.getElementById('customer-list').innerHTML=filtered.length?filtered.map(c=>{
    const key=getTierKey(c.points),next=nextTierInfo(c.points);
    const prev=prevTierThreshold(c.points);
    const pct=next?Math.min(100,Math.round(((c.points-prev)/(next.threshold-prev))*100)):100;
    return `<div class="card" style="cursor:pointer;" onclick="showCustomerDetail('${c.id}')">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div><div style="font-size:17px;font-weight:700;">${c.name}</div>
        <div style="font-size:13px;color:#888;">${c.email} · ${c.phone}</div>
        <div style="font-size:13px;color:#666;">${c.vehicle}</div></div>
        <div style="text-align:right;"><span class="tier-badge tier-${key}">${getTierName(c.points)}</span>
        <div style="font-size:22px;font-weight:900;color:#e05c2a;">${c.points.toLocaleString()} pts</div></div>
      </div>
      <div class="progress-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>
      <div class="progress-label">${next?`${c.points}/${next.threshold} pts to ${next.name}`:'🏁 Max tier!'}</div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;">
        <div style="display:flex;gap:20px;font-size:13px;color:#888;">
          <span>💰 $${c.totalSpent.toLocaleString()}</span>
          <span>👥 ${c.referrals} referrals</span>
          <span>🔧 ${c.visits} visits</span>
        </div>
        <div style="display:flex;gap:8px;" onclick="event.stopPropagation()">
          <button class="btn btn-sm btn-outline" onclick="adjustPointsPrompt('${c.id}')">✏️ Pts</button>
          <button class="btn btn-sm" style="background:#3a0a0a;color:#e05c2a;border:1px solid #5a1a1a;" onclick="removeCustomer('${c.id}')">🗑</button>
        </div>
      </div></div>`;
  }).join(''):'<div class="card" style="text-align:center;color:#555;">No customers found.</div>';
}
function filterCustomers(val){renderCustomers(val);}

function showCustomerDetail(id){
